 --Total balance per customer
 select customer_id ,SUM(balance)
 from accounts
 group by customer_id;
 
 --Customers With Total Balance
 SELECT customers.name,accounts.balance
 from customers
 join accounts
 on customers.customer_id = accounts.customer_id
 group by customers.name;
 
 --Customers With Balance Greater Than 5000
 SELECT customers.name,accounts.balance
 from customers
 join accounts
 on customers.customer_id = accounts.customer_id
where balance> 5000;

--Customer With Highest Total Balance
 SELECT customers.name,accounts.balance AS total_balance 
 from customers
 join accounts
 on customers.customer_id = accounts.customer_id
 group by customers.name
 order by total_balance DESC
 limit  1;
 
 
 --Customers Without Accounts
 select customers.name
 from customers
 left join accounts
 on customers.customer_id = accounts.customer_id
 where accounts.account_id is NULL;
 
 --Find accounts with balance above average
 select balance
 from accounts
 where balance > (
 select AVG(balance)
  from accounts) ;
 
 --CASE Statement
SELECT name,
CASE
    WHEN age >= 35 THEN 'Senior Customer'
    ELSE 'Young Customer'
END AS category
FROM customers;


--Ranks Customer by Balance
select customer_id, balance
from (
select customer_id,balance,
RANK() OVER (order by balance DESC ) AS  Balance_Ranking
from accounts ) 
  where Balance_Ranking = 2;


--top 3 customers with the highest total transaction amount
select customer_id, SUM(balance) as Total_transactions
from accounts
group by customer_id 
order by Total_transactions DESC 
limit 3;


-- Use of OFFSET
select name,balance
from customers
join accounts
on customers.customer_id = accounts.customer_id
WHERE balance < (
    SELECT MAX(balance)
    FROM accounts
)
ORDER BY balance DESC
LIMIT 1 offset 1;


--another query 
select MAX(balance)
from accounts
  where balance < (
  select MAX(balance)
  from accounts
        );
--Dense rank 
select customer_id,balance,
DENSE_RANK() OVER (ORDER by balance desc )
from accounts
limit 2;

--Third highest balance
select customer_id, balance
from accounts
order by balance desc
limit 1 offset 2;

--Customer with highest balance
select name,balance
from customers
join accounts 
on customers.customer_id = accounts.customer_id
order by balance desc 
limit 1;

--Total balance per customer sorted highest first
select customers.name, accounts.balance
from customers
join accounts
on customers.customer_id = accounts.customer_id
order by accounts.balance desc;


-- Find duplicates
select city , count(*)
from customers 
group by city 
having count(*)>1;

--Find duplicate names
select name, count(*)
from customers 
group by name
HAVING COUNT(*) > 1;

